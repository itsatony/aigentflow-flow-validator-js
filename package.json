{
  "name": "@vaudience/aigentflow-flow-validator",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Static, offline validator for AIgentFlow workflow YAML. Works in Node, the browser, and as a CLI.",
  "keywords": [
    "aigentflow",
    "workflow",
    "yaml",
    "validator",
    "linter",
    "flow"
  ],
  "license": "MIT",
  "author": "vAudience.AI",
  "homepage": "https://github.com/itsatony/aigentflow-flow-validator-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsatony/aigentflow-flow-validator-js.git"
  },
  "bugs": {
    "url": "https://github.com/itsatony/aigentflow-flow-validator-js/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "aigentflow-validate": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "PARITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
